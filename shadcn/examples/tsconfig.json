{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@data-table": ["../registry/default/data-table/index.ts"],
      "@data-table/*": ["../registry/default/data-table/*"],
      "@/*": ["../*"]
    }
  },
  "include": ["src", "server", "../registry", "vite.config.ts"]
}
