{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@data-table": ["../src/data-table/index.ts"],
      "@data-table/*": ["../src/data-table/*"]
    }
  },
  "include": ["src", "../src", "vite.config.ts"]
}
