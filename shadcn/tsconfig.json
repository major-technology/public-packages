{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"declaration": false,
		"noEmit": true,
		"isolatedModules": true
	},
	"include": ["src/**/*", "scripts/**/*"]
}
