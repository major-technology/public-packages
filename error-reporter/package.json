{
  "name": "@major-tech/error-reporter",
  "version": "0.2.4",
  "description": "Error reporting client for Major applications — captures and batches errors to the Major API",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs",
      "default": "./dist/next.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc && node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "keywords": [
    "major",
    "error",
    "reporter",
    "sentry"
  ],
  "author": "Major Technology",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/major-technology/public-packages.git",
    "directory": "error-reporter"
  },
  "homepage": "https://github.com/major-technology/public-packages/tree/main/error-reporter#readme",
  "bugs": {
    "url": "https://github.com/major-technology/public-packages/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "typescript": "^5.9.3"
  }
}
